<div id="list-socials">
    <p>Total : <span class="text-small">{{ socials.getTotalItemCount }}</span></p>
    <div class="d-flex flex-wrap p-3 rounded-3 align-items-center bg-primary bg-opacity-25 fw-bold mb-3">
        <div class="col">Nom</div>
        <div class="col">Couleur</div>
        <div class="col">Icon</div>
        <div class="col-12 col-sm mt-3 mt-sm-0">Action</div>
    </div>

    {% for social in socials %}
        <div class="d-flex flex-wrap bg-light px-3 py-2 rounded-3 align-items-center mb-2">
                <div class="col col-sm">{{ social.name }}</div>
                <div class="col col-sm">
                    <span class="py-1 px-3 rounded-5" style="background-color: {{ social.color }}"></span>
                </div>
                <div class="col col-sm"><i class="{{ social.icon }}"></i></div>
                
                <div class="col-12 col-sm mt-3 mt-sm-0">
                    <a class="btn btn-sm btn-secondary text-white text-uppercase" href="{{ path('admin.social.show', {id: social.id}) }}">
                        <i class="fa-solid fa-eye"></i>
                    </a>
                    <turbo-frame id="admin-social-remove">
                        <a class="btn btn-sm btn-danger text-white text-uppercase" href="{{ path('admin.social.remove', {id: social.id}) }}">
                            <i class="fa-solid fa-trash"></i>
                        </a>
                    </turbo-frame>
                </div>
        </div>
    {% endfor %}

    <div class="mt-4">
        {{ knp_pagination_render(socials) }}
    </div>
</div>