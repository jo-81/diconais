<div id="list-socials">
    <p>Total : <span class="text-small">{{ socials.getTotalItemCount }}</span></p>
    <div class="d-flex flex-wrap p-3 rounded-3 align-items-center bg-primary bg-opacity-25 fw-bold mb-3">
        <div class="col-12 col-sm">Nom</div>
        <div class="col-12 col-sm">Couleur</div>
        <div class="col-12 col-sm">Icon</div>
        <div class="col-12 col-sm">Action</div>
    </div>

    {% for social in socials %}
        <div class="d-flex flex-wrap bg-light px-3 py-2 rounded-3 align-items-center mb-2">
            <div class="col-12 col-sm">{{ social.name }}</div>
            <div class="col-12 col-sm m-sm-0 mb-3 mt-2">
                <span class="py-1 px-3 rounded-5" style="background-color: {{ social.color }}"></span>
            </div>
            <div class="col-12 col-sm m-sm-0 mb-3 mt-2">{{ social.icon | raw }}</div>
            <div class="col-12 col-sm">
                <a class="btn btn-sm btn-secondary text-white text-uppercase" href="{{ path('admin.social.show', {id: social.id}) }}">
                    <i class="fa-solid fa-eye"></i>
                </a>

                <a class="btn btn-sm btn-danger text-white text-uppercase" href="#">
                    <i class="fa-solid fa-trash"></i>
                </a>
            </div>
        </div>
    {% endfor %}

    <div class="mt-4">
        {{ knp_pagination_render(socials) }}
    </div>
</div>